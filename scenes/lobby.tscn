[gd_scene load_steps=3 format=3 uid="uid://burnbridgers_lobby"]

[ext_resource type="Script" path="res://scripts/lobby.gd" id="1_lobby"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_lobby_card"]
bg_color = Color(0.14, 0.11, 0.09, 0.94)
corner_radius_top_left = 16
corner_radius_top_right = 16
corner_radius_bottom_right = 16
corner_radius_bottom_left = 16
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.48, 0.35, 0.22, 0.84)
shadow_size = 16
shadow_color = Color(0, 0, 0, 0.4)
content_margin_left = 18.0
content_margin_top = 16.0
content_margin_right = 18.0
content_margin_bottom = 16.0

[node name="Lobby" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_lobby")

[node name="BackdropTint" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.08, 0.06, 0.05, 0.56)
mouse_filter = 2

[node name="LobbyCard" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -235.0
offset_top = -235.0
offset_right = 235.0
offset_bottom = 235.0
theme_override_styles/panel = SubResource("StyleBoxFlat_lobby_card")

[node name="VBoxContainer" type="VBoxContainer" parent="LobbyCard"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
alignment = 1
theme_override_constants/separation = 12

[node name="LobbyIdLabel" type="Label" parent="LobbyCard/VBoxContainer"]
text = "Lobby ID: ..."
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.95, 0.9, 0.83, 1)

[node name="LobbyStatusLabel" type="Label" parent="LobbyCard/VBoxContainer"]
text = "Lobby Members: 0/4"
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.79, 0.7, 0.6, 0.95)

[node name="PlayersTitle" type="Label" parent="LobbyCard/VBoxContainer"]
text = "Players:"
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.9, 0.8, 0.69, 1)

[node name="PlayerList" type="VBoxContainer" parent="LobbyCard/VBoxContainer"]
theme_override_constants/separation = 4

[node name="HandshakeStatusLabel" type="Label" parent="LobbyCard/VBoxContainer"]
text = "Join test handshake: Idle"
autowrap_mode = 2
theme_override_colors/font_color = Color(0.62, 0.56, 0.5, 1)

[node name="FriendsTitle" type="Label" parent="LobbyCard/VBoxContainer"]
text = "Invite Online Friends:"
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.9, 0.8, 0.69, 1)

[node name="FriendsScroll" type="ScrollContainer" parent="LobbyCard/VBoxContainer"]
custom_minimum_size = Vector2(0, 140)

[node name="FriendsList" type="VBoxContainer" parent="LobbyCard/VBoxContainer/FriendsScroll"]
