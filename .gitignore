# Godot-generated cache and import data
.godot/
!.godot/extension_list.cfg
*.import
*.translation
*.uid

# Export configuration (may contain sensitive data)
export_presets.cfg

# GodotSteam GDExtension binaries — installed via setup scripts
addons/godotsteam/

# LimboAI GDExtension binaries — installed via setup scripts
addons/limboai/

# Ziva AI agent GDExtension binaries — installed via ziva.sh/install.sh
addons/ziva_agent/

# Steam test app ID file — never commit
steam_appid.txt

# Local debug log output from run.ps1 -Mode debug
logs/

# OS clutter
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.cursor/*
!.cursor/rules/
!.cursor/rules/*.mdc
.vscode/
*.swp
