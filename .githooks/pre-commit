#!/usr/bin/env sh
set -eu

current_branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$current_branch" = "HEAD" ]; then
  echo "ERROR: Detached HEAD detected. Create a feature branch before committing."
  echo "Example: git checkout -b feature/your-change"
  exit 1
fi

if [ "$current_branch" = "main" ] || [ "$current_branch" = "master" ]; then
  echo "ERROR: Direct commits to $current_branch are blocked."
  echo "Create a feature branch first:"
  echo "  git checkout -b feature/your-change"
  exit 1
fi

case "$current_branch" in
  feature/*)
    ;;
  *)
    echo "ERROR: Branch '$current_branch' is not allowed for commits."
    echo "Use a feature branch name like:"
    echo "  feature/short-description"
    exit 1
    ;;
esac
